{
  "name": "axios-api-testing",
  "version": "1.0.0",
  "description": "Lightweight API testing suite built with Axios to validate endpoints, responses, and status codes.",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS='--import tsx' mocha 'src/tests/**/*.test.ts' --timeout 30000",
    "test:auth": "NODE_OPTIONS='--import tsx' mocha 'src/tests/auth.test.ts' --timeout 30000",
    "test:booking": "NODE_OPTIONS='--import tsx' mocha 'src/tests/booking.test.ts' --timeout 30000"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guillesubeldia/axios-api-testing.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/guillesubeldia/axios-api-testing/issues"
  },
  "homepage": "https://github.com/guillesubeldia/axios-api-testing#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "mocha": "^11.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
